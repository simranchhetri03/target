class Solution(object):
    def countPairs(self, nums, target):
        count = 0

        for i in range(len(nums)):
            for j in range(i + 1, len(nums)):
                if nums[i] + nums[j] < target:
                    count += 1

        return count


nums = [-1, 1, 2, 3, 1]
target = 2

obj = Solution()
answer = obj.countPairs(nums, target)

print(answer)